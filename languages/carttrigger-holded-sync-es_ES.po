msgid "CartTrigger – Holded requires WooCommerce to be active."
msgstr "CartTrigger – Holded Sync requiere que WooCommerce esté activo."

msgid "CartTrigger – Holded Sync"
msgstr "CartTrigger – Holded Sync"

msgid "Holded Sync"
msgstr "Holded Sync"

msgid "Connection"
msgstr "Conexión"

msgid "Holded API Key"
msgstr "Clave API de Holded"

msgid "Test connection"
msgstr "Probar conexión"

msgid "Warehouse"
msgstr "Almacén"

msgid "— Load warehouses —"
msgstr "— Cargar almacenes —"

msgid "Load warehouses"
msgstr "Cargar almacenes"

msgid "Default tax rate (%)"
msgstr "Tipo impositivo predeterminado (%)"

msgid "Fallback tax rate if WooCommerce cannot determine it automatically. Default: 21 (Spain — standard VAT)."
msgstr "Tipo impositivo de respaldo si WooCommerce no puede determinarlo automáticamente. Por defecto: 21 (España — IVA estándar)."

msgid "Sync settings"
msgstr "Ajustes de sincronización"

msgid "Enable sync"
msgstr "Activar sincronización"

msgid "Activate bidirectional sync (WooCommerce ↔ Holded)"
msgstr "Activar sincronización bidireccional (WooCommerce ↔ Holded)"

msgid "Pull interval"
msgstr "Intervalo de importación"

msgid "minutes"
msgstr "minutos"

msgid "How often to pull changes from Holded into WooCommerce. Minimum: 5 min. Default: 15."
msgstr "Con qué frecuencia importar cambios de Holded a WooCommerce. Mínimo: 5 min. Por defecto: 15."

msgid "Prices include tax"
msgstr "Precios con IVA incluido"

msgid "Prices in WooCommerce are tax-inclusive — strip tax before sending to Holded"
msgstr "Los precios en WooCommerce incluyen IVA — eliminar el IVA antes de enviar a Holded"

msgid "Sync stock"
msgstr "Sincronizar stock"

msgid "Sync stock quantity (both directions)"
msgstr "Sincronizar cantidad de stock (ambas direcciones)"

msgid "Sync prices"
msgstr "Sincronizar precios"

msgid "Sync regular price (both directions)"
msgstr "Sincronizar precio normal (ambas direcciones)"

msgid "Sync description"
msgstr "Sincronizar descripción"

msgid "Sync product description (both directions)"
msgstr "Sincronizar descripción del producto (ambas direcciones)"

msgid "Append brand to name"
msgstr "Añadir marca al nombre"

msgid "Append the product brand (product_brand taxonomy) to the product name when syncing to Holded"
msgstr "Añade la marca del producto (taxonomía product_brand) al nombre del producto al sincronizar con Holded"

msgid "Enable log"
msgstr "Activar registro"

msgid "Enable log (last 100 messages)"
msgstr "Activar registro (últimos 100 mensajes)"

msgid "Save settings"
msgstr "Guardar ajustes"

msgid "Manual sync"
msgstr "Sincronización manual"

#, php-format
msgid "Pull all products from Holded and update WooCommerce. Last pull: %s"
msgstr "Importar todos los productos de Holded y actualizar WooCommerce. Última importación: %s"

msgid "never"
msgstr "nunca"

msgid "Pull from Holded now"
msgstr "Importar desde Holded ahora"

msgid "System log"
msgstr "Registro del sistema"

msgid "Clear log"
msgstr "Borrar registro"

msgid "Time"
msgstr "Hora"

msgid "Event"
msgstr "Evento"

msgid "Product ID"
msgstr "ID de producto"

msgid "Message"
msgstr "Mensaje"

msgid "Unauthorized"
msgstr "No autorizado"

msgid "Connection successful."
msgstr "Conexión correcta."

msgid "Pull completed."
msgstr "Importación completada."

msgid "Testing…"
msgstr "Probando…"

msgid "Pulling from Holded…"
msgstr "Importando desde Holded…"

msgid "Success"
msgstr "Correcto"

msgid "Error"
msgstr "Error"

msgid "Holded API key is not configured."
msgstr "La clave API de Holded no está configurada."

msgid "Description for Holded"
msgstr "Descripción para Holded"

msgid "Short description sent to Holded. Leave empty to skip."
msgstr "Descripción breve enviada a Holded. Dejar vacío para omitir."

msgid "Replaces the full product description when syncing to Holded."
msgstr "Reemplaza la descripción completa del producto al sincronizar con Holded."

msgid "Cost price"
msgstr "Precio de coste"

msgid "Cost price sent to Holded (net, excluding tax)."
msgstr "Precio de coste enviado a Holded (neto, sin IVA)."

msgid "Barcode"
msgstr "Código de barras"

msgid "Barcode (EAN, UPC…) sent to Holded."
msgstr "Código de barras (EAN, UPC…) enviado a Holded."

msgid "Holded product ID"
msgstr "ID de producto en Holded"
