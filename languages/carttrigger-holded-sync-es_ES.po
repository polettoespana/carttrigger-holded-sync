msgid "CartTrigger – Holded requires WooCommerce to be active."
msgstr "CartTrigger – Holded Sync requiere que WooCommerce esté activo."

msgid "CartTrigger – Holded Sync"
msgstr "CartTrigger – Holded Sync"

msgid "Holded Sync"
msgstr "Holded Sync"

msgid "Connection"
msgstr "Conexión"

msgid "Holded API Key"
msgstr "Clave API de Holded"

msgid "Test connection"
msgstr "Probar conexión"

msgid "Warehouse"
msgstr "Almacén"

msgid "— Load warehouses —"
msgstr "— Cargar almacenes —"

msgid "Load warehouses"
msgstr "Cargar almacenes"

msgid "Default tax rate (%)"
msgstr "Tipo impositivo predeterminado (%)"

msgid "Fallback tax rate if WooCommerce cannot determine it automatically. Default: 21 (Spain — standard VAT)."
msgstr "Tipo impositivo de respaldo si WooCommerce no puede determinarlo automáticamente. Por defecto: 21 (España — IVA estándar)."

msgid "Sync settings"
msgstr "Ajustes de sincronización"

msgid "Enable sync"
msgstr "Activar sincronización"

msgid "Activate bidirectional sync (WooCommerce ↔ Holded)"
msgstr "Activar sincronización bidireccional (WooCommerce ↔ Holded)"

msgid "Pull interval"
msgstr "Intervalo de importación"

msgid "minutes"
msgstr "minutos"

msgid "How often to pull changes from Holded into WooCommerce. Minimum: 5 min. Default: 15."
msgstr "Con qué frecuencia importar cambios de Holded a WooCommerce. Mínimo: 5 min. Por defecto: 15."

msgid "Prices include tax"
msgstr "Precios con IVA incluido"

msgid "Prices in WooCommerce are tax-inclusive — strip tax before sending to Holded"
msgstr "Los precios en WooCommerce incluyen IVA — eliminar el IVA antes de enviar a Holded"

msgid "Sync stock"
msgstr "Sincronizar stock"

msgid "Sync stock quantity (both directions)"
msgstr "Sincronizar cantidad de stock (ambas direcciones)"

msgid "Sync prices"
msgstr "Sincronizar precios"

msgid "Sync regular price (both directions)"
msgstr "Sincronizar precio normal (ambas direcciones)"

msgid "Sync description"
msgstr "Sincronizar descripción"

msgid "Sync product description (both directions)"
msgstr "Sincronizar descripción del producto (ambas direcciones)"

msgid "Append brand to name"
msgstr "Añadir marca al nombre"

msgid "Append the product brand (product_brand taxonomy) to the product name when syncing to Holded"
msgstr "Añade la marca del producto (taxonomía product_brand) al nombre del producto al sincronizar con Holded"

msgid "Sync image"
msgstr "Sincronizar imagen"

msgid "Send the product featured image URL to Holded (WC → Holded only)"
msgstr "Envía la URL de la imagen destacada del producto a Holded (solo WC → Holded)"

msgid "Overwrite existing image in Holded (if unchecked, image is sent only on first sync)"
msgstr "Sobrescribir imagen existente en Holded (si no está marcado, la imagen se envía solo en el primer sync)"

msgid "Enable log"
msgstr "Activar registro"

msgid "Enable log (last 50 messages)"
msgstr "Activar registro (últimos 50 mensajes)"

msgid "Save settings"
msgstr "Guardar ajustes"

msgid "Manual sync"
msgstr "Sincronización manual"

#, php-format
msgid "Pull all products from Holded and update WooCommerce. Last pull: %s"
msgstr "Importar todos los productos de Holded y actualizar WooCommerce. Última importación: %s"

msgid "never"
msgstr "nunca"

msgid "Pull from Holded now"
msgstr "Importar desde Holded ahora"

msgid "System log"
msgstr "Registro del sistema"

msgid "Clear log"
msgstr "Borrar registro"

msgid "Time"
msgstr "Hora"

msgid "Event"
msgstr "Evento"

msgid "Product ID"
msgstr "ID de producto"

msgid "Message"
msgstr "Mensaje"

msgid "Unauthorized"
msgstr "No autorizado"

msgid "Connection successful."
msgstr "Conexión correcta."

msgid "Pull completed."
msgstr "Importación completada."

msgid "Testing…"
msgstr "Probando…"

msgid "Pulling from Holded…"
msgstr "Importando desde Holded…"

msgid "Success"
msgstr "Correcto"

msgid "Error"
msgstr "Error"

msgid "Holded API key is not configured."
msgstr "La clave API de Holded no está configurada."

msgid "Description for Holded"
msgstr "Descripción para Holded"

msgid "Short description sent to Holded. Leave empty to skip."
msgstr "Descripción breve enviada a Holded. Dejar vacío para omitir."

msgid "Replaces the full product description when syncing to Holded."
msgstr "Reemplaza la descripción completa del producto al sincronizar con Holded."

msgid "Cost price"
msgstr "Precio de coste"

msgid "Cost price sent to Holded (net, excluding tax)."
msgstr "Precio de coste enviado a Holded (neto, sin IVA)."

msgid "Barcode"
msgstr "Código de barras"

msgid "Barcode (EAN, UPC…) sent to Holded."
msgstr "Código de barras (EAN, UPC…) enviado a Holded."

msgid "Holded product ID"
msgstr "ID de producto en Holded"

msgid "Loading…"
msgstr "Cargando…"

msgid "— Select warehouse —"
msgstr "— Seleccionar almacén —"

msgid "No warehouses found."
msgstr "No se han encontrado almacenes."

msgid "Description source"
msgstr "Fuente de la descripción"

msgid "Custom field (Holded Sync tab)"
msgstr "Campo personalizado (pestaña Holded Sync)"

msgid "Full product description (WooCommerce)"
msgstr "Descripción completa del producto (WooCommerce)"

msgid "WC → Holded: which field to read the description from."
msgstr "WC → Holded: desde qué campo leer la descripción."

msgid "Holded → WC: which field to write the description to."
msgstr "Holded → WC: en qué campo escribir la descripción."

msgid "Event reference"
msgstr "Referencia de eventos"

msgid "Full payload sent to Holded when a product is saved in WooCommerce (debug)."
msgstr "Payload completo enviado a Holded cuando se guarda un producto en WooCommerce (depuración)."

msgid "Error returned by Holded when creating or updating a product."
msgstr "Error devuelto por Holded al crear o actualizar un producto."

msgid "Error returned by Holded when updating stock quantity."
msgstr "Error devuelto por Holded al actualizar la cantidad de stock."

msgid "Pull from Holded started. Message indicates whether triggered by the scheduler or manually."
msgstr "Importación desde Holded iniciada. El mensaje indica si fue activada por el programador o manualmente."

msgid "API error while fetching products from Holded."
msgstr "Error de API al obtener productos de Holded."

msgid "Pull finished. Message shows how many products were processed."
msgstr "Importación finalizada. El mensaje indica cuántos productos se han procesado."

msgid "A new product was created in WooCommerce from Holded data."
msgstr "Se ha creado un nuevo producto en WooCommerce con datos de Holded."

msgid "An existing WooCommerce product was updated with data from Holded."
msgstr "Se ha actualizado un producto existente en WooCommerce con datos de Holded."

msgid "Error while saving a product in WooCommerce during the pull."
msgstr "Error al guardar un producto en WooCommerce durante la importación."

#, php-format
msgid "Next scheduled run: %s"
msgstr "Próxima ejecución programada: %s"

msgid "No scheduled run found. Enable sync to activate the scheduler."
msgstr "No se encontró ninguna ejecución programada. Activa la sincronización para activar el programador."

msgid "Sync direction"
msgstr "Dirección de sincronización"

msgid "WooCommerce → Holded (real-time on product save / stock change)"
msgstr "WooCommerce → Holded (tiempo real al guardar producto / cambiar stock)"

msgid "Holded → WooCommerce (scheduled pull every X minutes)"
msgstr "Holded → WooCommerce (importación programada cada X minutos)"

msgid "Sync sale price (WC → Holded): if a sale price is set in WooCommerce, send it to Holded instead of the regular price"
msgstr "Sincronizar precio de oferta (WC → Holded): si hay un precio de oferta en WooCommerce, enviarlo a Holded en lugar del precio normal"

msgid "Push to Holded now"
msgstr "Actualizar desde WooCommerce ahora"

msgid "Send all WooCommerce products to Holded now (create or update)."
msgstr "Envía todos los productos de WooCommerce a Holded ahora (creación o actualización)."

msgid "Pushing to Holded…"
msgstr "Enviando a Holded…"

#, php-format
msgid "Push completed: %d product sent."
msgid_plural "Push completed: %d products sent."
msgstr[0] "Push completado: %d producto enviado."
msgstr[1] "Push completado: %d productos enviados."

msgid "Known limitations"
msgstr "Limitaciones conocidas"

msgid "Multiple price tiers"
msgstr "Precios múltiples (tarifas)"

msgid "Product images"
msgstr "Imágenes de producto"

msgid "The Holded API does not support setting product images via REST API. Images must be uploaded manually through the Holded interface."
msgstr "La API de Holded no permite establecer imágenes de producto vía REST API. Las imágenes deben subirse manualmente desde la interfaz de Holded."

msgid "The Holded API does not currently expose product price rates (tariffe). Syncing secondary prices (e.g. Ho.re.ca) is not possible until Holded adds API support for this feature. This limitation will be addressed as soon as it becomes available."
msgstr "La API de Holded no expone actualmente las tarifas de producto. La sincronización de tarifas adicionales a la Tarifa principal no es posible hasta que Holded añada soporte API para esta función. La limitación se resolverá en cuanto esté disponible."

msgid "Reschedule"
msgstr "Reprogramar"

msgid "Action Scheduler not available."
msgstr "Action Scheduler no disponible."

msgid "Scheduled but could not read next run time."
msgstr "Programado, pero no se pudo leer la próxima hora de ejecución."

msgid "Existing Holded product found by SKU and linked to the WooCommerce product (avoids duplicate creation)."
msgstr "Producto de Holded existente encontrado por SKU y vinculado al producto de WooCommerce (evita la creación de duplicados)."

msgid "Holded variant IDs fetched and stored on WC variations after a successful push."
msgstr "IDs de variantes de Holded obtenidos y guardados en las variaciones de WC tras un push exitoso."

msgid "Variable product updates"
msgstr "Actualización de productos variables"

msgid "The Holded API does not support updating variable products (kind: variants) via PUT. After the initial creation, only stock is kept in sync. Name, price and description changes on variable products must be made manually in Holded."
msgstr "La API de Holded no permite actualizar productos variables (kind: variants) mediante PUT. Tras la creación inicial, solo se sincroniza el stock. Los cambios de nombre, precio y descripción en productos variables deben realizarse manualmente en Holded."
