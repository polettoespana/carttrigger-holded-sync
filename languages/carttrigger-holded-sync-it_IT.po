msgid "CartTrigger – Holded requires WooCommerce to be active."
msgstr "CartTrigger – Holded Sync richiede che WooCommerce sia attivo."

msgid "CartTrigger – Holded Sync"
msgstr "CartTrigger – Holded Sync"

msgid "Holded Sync"
msgstr "Holded Sync"

msgid "Connection"
msgstr "Connessione"

msgid "Holded API Key"
msgstr "Chiave API Holded"

msgid "Test connection"
msgstr "Testa connessione"

msgid "Warehouse"
msgstr "Magazzino"

msgid "— Load warehouses —"
msgstr "— Carica magazzini —"

msgid "Load warehouses"
msgstr "Carica magazzini"

msgid "Default tax rate (%)"
msgstr "Aliquota IVA predefinita (%)"

msgid "Fallback tax rate if WooCommerce cannot determine it automatically. Default: 21 (Spain — standard VAT)."
msgstr "Aliquota IVA di fallback se WooCommerce non riesce a determinarla automaticamente. Default: 21 (Spagna — IVA standard)."

msgid "Sync settings"
msgstr "Impostazioni sincronizzazione"

msgid "Enable sync"
msgstr "Abilita sincronizzazione"

msgid "Activate bidirectional sync (WooCommerce ↔ Holded)"
msgstr "Attiva sincronizzazione bidirezionale (WooCommerce ↔ Holded)"

msgid "Pull interval"
msgstr "Intervallo di aggiornamento"

msgid "minutes"
msgstr "minuti"

msgid "How often to pull changes from Holded into WooCommerce. Minimum: 5 min. Default: 15."
msgstr "Con quale frequenza recuperare le modifiche da Holded in WooCommerce. Minimo: 5 min. Default: 15."

msgid "Prices include tax"
msgstr "Prezzi IVA inclusa"

msgid "Prices in WooCommerce are tax-inclusive — strip tax before sending to Holded"
msgstr "I prezzi in WooCommerce sono IVA inclusa — scorporare l'IVA prima di inviare a Holded"

msgid "Sync stock"
msgstr "Sincronizza stock"

msgid "Sync stock quantity (both directions)"
msgstr "Sincronizza quantità in stock (entrambe le direzioni)"

msgid "Sync prices"
msgstr "Sincronizza prezzi"

msgid "Sync regular price (both directions)"
msgstr "Sincronizza prezzo regolare (entrambe le direzioni)"

msgid "Sync description"
msgstr "Sincronizza descrizione"

msgid "Sync product description (both directions)"
msgstr "Sincronizza descrizione prodotto (entrambe le direzioni)"

msgid "Append brand to name"
msgstr "Aggiungi brand al nome"

msgid "Append the product brand (product_brand taxonomy) to the product name when syncing to Holded"
msgstr "Aggiunge il brand del prodotto (tassonomia product_brand) al nome del prodotto durante la sincronizzazione con Holded"

msgid "Sync image"
msgstr "Sincronizza immagine"

msgid "Send the product featured image URL to Holded (WC → Holded only)"
msgstr "Invia l'URL dell'immagine in evidenza del prodotto a Holded (solo WC → Holded)"

msgid "Overwrite existing image in Holded (if unchecked, image is sent only on first sync)"
msgstr "Sovrascrivi l'immagine esistente in Holded (se deselezionato, l'immagine viene inviata solo al primo sync)"

msgid "Enable log"
msgstr "Abilita log"

msgid "Enable log (last 50 messages)"
msgstr "Abilita log (ultimi 50 messaggi)"

msgid "Save settings"
msgstr "Salva impostazioni"

msgid "Manual sync"
msgstr "Sincronizzazione manuale"

#, php-format
msgid "Pull all products from Holded and update WooCommerce. Last pull: %s"
msgstr "Recupera tutti i prodotti da Holded e aggiorna WooCommerce. Ultimo aggiornamento: %s"

msgid "never"
msgstr "mai"

msgid "Pull from Holded now"
msgstr "Aggiorna da Holded ora"

msgid "System log"
msgstr "Log di sistema"

msgid "Clear log"
msgstr "Cancella log"

msgid "Time"
msgstr "Ora"

msgid "Event"
msgstr "Evento"

msgid "Product ID"
msgstr "ID prodotto"

msgid "Message"
msgstr "Messaggio"

msgid "Unauthorized"
msgstr "Non autorizzato"

msgid "Connection successful."
msgstr "Connessione riuscita."

msgid "Pull completed."
msgstr "Aggiornamento completato."

msgid "Testing…"
msgstr "Test in corso…"

msgid "Pulling from Holded…"
msgstr "Aggiornamento da Holded in corso…"

msgid "Success"
msgstr "Operazione riuscita"

msgid "Error"
msgstr "Errore"

msgid "Holded API key is not configured."
msgstr "La chiave API di Holded non è configurata."

msgid "Description for Holded"
msgstr "Descrizione per Holded"

msgid "Short description sent to Holded. Leave empty to skip."
msgstr "Descrizione breve inviata a Holded. Lascia vuoto per saltare."

msgid "Replaces the full product description when syncing to Holded."
msgstr "Sostituisce la descrizione completa del prodotto durante la sincronizzazione con Holded."

msgid "Cost price"
msgstr "Prezzo di costo"

msgid "Cost price sent to Holded (net, excluding tax)."
msgstr "Prezzo di costo inviato a Holded (netto, IVA esclusa)."

msgid "Barcode"
msgstr "Codice a barre"

msgid "Barcode (EAN, UPC…) sent to Holded."
msgstr "Codice a barre (EAN, UPC…) inviato a Holded."

msgid "Holded product ID"
msgstr "ID prodotto Holded"

msgid "Loading…"
msgstr "Caricamento…"

msgid "— Select warehouse —"
msgstr "— Seleziona magazzino —"

msgid "No warehouses found."
msgstr "Nessun magazzino trovato."

msgid "Description source"
msgstr "Fonte della descrizione"

msgid "Custom field (Holded Sync tab)"
msgstr "Campo personalizzato (tab Holded Sync)"

msgid "Full product description (WooCommerce)"
msgstr "Descrizione completa del prodotto (WooCommerce)"

msgid "WC → Holded: which field to read the description from."
msgstr "WC → Holded: da quale campo leggere la descrizione."

msgid "Holded → WC: which field to write the description to."
msgstr "Holded → WC: in quale campo scrivere la descrizione."

msgid "Event reference"
msgstr "Riferimento eventi"

msgid "Full payload sent to Holded when a product is saved in WooCommerce (debug)."
msgstr "Payload completo inviato a Holded quando un prodotto viene salvato in WooCommerce (debug)."

msgid "Error returned by Holded when creating or updating a product."
msgstr "Errore restituito da Holded durante la creazione o l'aggiornamento di un prodotto."

msgid "Error returned by Holded when updating stock quantity."
msgstr "Errore restituito da Holded durante l'aggiornamento della quantità in stock."

msgid "Pull from Holded started. Message indicates whether triggered by the scheduler or manually."
msgstr "Pull da Holded avviato. Il messaggio indica se è stato avviato dallo scheduler o manualmente."

msgid "API error while fetching products from Holded."
msgstr "Errore API durante il recupero dei prodotti da Holded."

msgid "Pull finished. Message shows how many products were processed."
msgstr "Pull completato. Il messaggio indica quanti prodotti sono stati elaborati."

msgid "A new product was created in WooCommerce from Holded data."
msgstr "Un nuovo prodotto è stato creato in WooCommerce dai dati di Holded."

msgid "An existing WooCommerce product was updated with data from Holded."
msgstr "Un prodotto esistente in WooCommerce è stato aggiornato con i dati di Holded."

msgid "Error while saving a product in WooCommerce during the pull."
msgstr "Errore durante il salvataggio di un prodotto in WooCommerce nel corso del pull."

#, php-format
msgid "Next scheduled run: %s"
msgstr "Prossima esecuzione pianificata: %s"

msgid "No scheduled run found. Enable sync to activate the scheduler."
msgstr "Nessuna esecuzione pianificata trovata. Abilita la sincronizzazione per attivare lo scheduler."

msgid "Automatic sync direction"
msgstr "Direzione della sincronizzazione automatica"

msgid "WooCommerce → Holded (real-time on product save / stock change)"
msgstr "WooCommerce → Holded (in tempo reale al salvataggio prodotto / variazione scorte)"

msgid "Holded → WooCommerce (scheduled pull every X minutes)"
msgstr "Holded → WooCommerce (pull pianificato ogni X minuti)"

msgid "Include draft products in WooCommerce → Holded sync (real-time and bulk push)"
msgstr "Includi i prodotti in bozza nella sincronizzazione WooCommerce → Holded (in tempo reale e push in blocco)"

msgid "These settings control automatic sync only. Manual sync (bulk push/pull) and single SKU sync always run regardless of these checkboxes."
msgstr "Queste impostazioni controllano solo la sincronizzazione automatica. Il sync manuale (push/pull in blocco) e il sync per SKU singolo funzionano sempre, indipendentemente da questi checkbox."

msgid "Sync sale price (WC → Holded): if a sale price is set in WooCommerce, send it to Holded instead of the regular price"
msgstr "Sincronizza prezzo in offerta (WC → Holded): se in WooCommerce è impostato un prezzo in offerta, invialo a Holded al posto del prezzo normale"

msgid "Push to Holded now"
msgstr "Aggiorna da WooCommerce ora"

msgid "Send all WooCommerce products to Holded now (create or update)."
msgstr "Invia tutti i prodotti WooCommerce a Holded ora (creazione o aggiornamento)."

msgid "Pushing to Holded…"
msgstr "Invio a Holded in corso…"

#, php-format
msgid "Push completed: %d product sent."
msgid_plural "Push completed: %d products sent."
msgstr[0] "Push completato: %d prodotto inviato."
msgstr[1] "Push completato: %d prodotti inviati."

msgid "Known limitations"
msgstr "Limitazioni note"

msgid "Multiple price tiers"
msgstr "Prezzi multipli (tariffe)"

msgid "Product images"
msgstr "Immagini prodotto"

msgid "The Holded API does not support setting product images via REST API. Images must be uploaded manually through the Holded interface."
msgstr "L'API di Holded non supporta l'impostazione delle immagini prodotto tramite REST API. Le immagini devono essere caricate manualmente dall'interfaccia di Holded."

msgid "The Holded API does not expose secondary price rates (e.g. Ho.re.ca). Only the main price is synced. Additional price tiers must be set manually in Holded for each product (including each variation pushed as a simple product). This limitation will be addressed as soon as Holded adds API support."
msgstr "L'API di Holded non espone le tariffe secondarie (es. Ho.re.ca). Viene sincronizzato solo il prezzo principale. Le tariffe aggiuntive devono essere impostate manualmente in Holded per ogni prodotto (inclusa ogni variante inviata come prodotto semplice). La limitazione verrà risolta non appena Holded aggiungerà il supporto API."

msgid "Reschedule"
msgstr "Ripianifica"

msgid "Action Scheduler not available."
msgstr "Action Scheduler non disponibile."

msgid "Scheduled but could not read next run time."
msgstr "Pianificato, ma impossibile leggere il prossimo orario di esecuzione."

msgid "Existing Holded product found by SKU and linked to the WooCommerce product (avoids duplicate creation)."
msgstr "Prodotto Holded esistente trovato tramite SKU e collegato al prodotto WooCommerce (evita la creazione di duplicati)."

msgid "Variable products — flattened to simple in Holded"
msgstr "Prodotti variabili — appiattiti come semplici in Holded"

msgid "Holded does not handle product variants reliably via API. Variable products in WooCommerce are pushed to Holded as separate simple products — one per variation — each with its own SKU. The parent variable product is never created in Holded. During pull (Holded → WC), each Holded product is matched by SKU to the corresponding WC variation; only stock and price are updated. The product structure in WooCommerce is never altered by the pull."
msgstr "Holded non gestisce correttamente le varianti di prodotto tramite API. I prodotti variabili in WooCommerce vengono inviati a Holded come prodotti semplici separati — uno per variante — ciascuno con il proprio SKU. Il prodotto padre variabile non viene mai creato in Holded. Durante il pull (Holded → WC), ogni prodotto Holded viene abbinato tramite SKU alla variazione WC corrispondente; vengono aggiornati solo stock e prezzo. La struttura dei prodotti in WooCommerce non viene mai modificata dal pull."

msgid "Variation name format"
msgstr "Formato nome variazione"

msgid "Space — Benaco Magnum 15 litros"
msgstr "Spazio — Benaco Magnum 15 litros"

msgid "Dash — Benaco – Magnum (1,5 litros)"
msgstr "Trattino — Benaco – Magnum (1,5 litros)"

msgid "Parentheses — Benaco (Magnum 15 litros)"
msgstr "Parentesi — Benaco (Magnum 15 litros)"

msgid "How to append attribute values to the parent product name when syncing variations to Holded."
msgstr "Come aggiungere i valori degli attributi al nome del prodotto padre durante la sincronizzazione delle variazioni con Holded."

msgid "Orders → Holded documents"
msgstr "Ordini → Documenti Holded"

msgid "Create document"
msgstr "Crea documento"

msgid "Automatically create a document in Holded when a WooCommerce order is paid"
msgstr "Crea automaticamente un documento in Holded alla conferma del pagamento di un ordine WooCommerce"

msgid "For each paid order, the plugin finds or creates the Holded contact (matched by NIF then by email), then creates the selected document type with all line items and shipping. The Holded contact ID and document ID are stored in the order meta."
msgstr "Per ogni ordine pagato, il plugin cerca o crea il contatto in Holded (prima per NIF, poi per email) e genera il tipo di documento selezionato con tutte le righe prodotto e la spedizione. L'ID contatto e l'ID documento di Holded vengono salvati nei meta dell'ordine."

msgid "Document type"
msgstr "Tipo documento"

msgid "Invoice (factura) — reduces Holded stock"
msgstr "Fattura — riduce lo stock in Holded"

msgid "Sales order (pedido de venta) — does not affect Holded stock"
msgstr "Ordine di vendita — non modifica lo stock in Holded"

msgid "If WooCommerce → Holded stock push is enabled, use Sales order to avoid double stock reduction. Use Invoice only if stock push is disabled and you want Holded to manage inventory via documents."
msgstr "Se la sincronizzazione stock WooCommerce → Holded è attiva, usa Ordine di vendita per evitare la doppia riduzione dello stock. Usa Fattura solo se il push stock è disabilitato e vuoi che Holded gestisca l'inventario tramite i documenti."

msgid "Avoid stock duplication"
msgstr "Evita duplicazione stock"

msgid "After creating an invoice, re-push WooCommerce stock to Holded to correct the stock reduction caused by the invoice"
msgstr "Dopo la creazione della fattura, reinvia lo stock di WooCommerce a Holded per correggere la riduzione causata dalla fattura"

msgid "Holded invoices automatically reduce stock. Enable this option to keep WooCommerce as the stock source of truth: after each invoice is created, the actual WC stock is sent back to Holded. Only applies to invoices — sales orders do not affect stock."
msgstr "Le fatture di Holded riducono automaticamente lo stock. Abilita questa opzione per mantenere WooCommerce come fonte di verità dello stock: dopo ogni fattura creata, lo stock reale di WC viene reinviato a Holded. Si applica solo alle fatture — gli ordini di vendita non modificano lo stock."

msgid "WooCommerce stock re-pushed to Holded after invoice creation to correct the stock reduction."
msgstr "Stock WooCommerce reinviato a Holded dopo la creazione della fattura per correggere la riduzione."

msgid "Error while re-pushing stock to Holded after invoice creation."
msgstr "Errore durante il reinvio dello stock a Holded dopo la creazione della fattura."

msgid "NIF/CIF meta key"
msgstr "Meta key del NIF/CIF"

msgid "Order meta key where the customer NIF/CIF/NIE is stored. Default: _billing_nif. This value is sent to Holded as the contact code (used to find existing contacts and avoid duplicates)."
msgstr "Chiave meta dell'ordine in cui è memorizzato il NIF/CIF/NIE del cliente. Default: _billing_nif. Questo valore viene inviato a Holded come codice del contatto (per trovare contatti esistenti ed evitare duplicati)."

msgid "Email meta key"
msgstr "Meta key dell'email"

msgid "Order meta key where the customer email is stored. Leave empty to use the standard WooCommerce billing email. Set a custom key only if your checkout stores the email in a non-standard field."
msgstr "Chiave meta dell'ordine in cui è memorizzata l'email del cliente. Lascia vuoto per usare l'email di fatturazione standard di WooCommerce. Imposta una chiave personalizzata solo se il checkout memorizza l'email in un campo non standard."

msgid "Holded contact ID resolved for a WooCommerce order (found or created)."
msgstr "ID contatto Holded risolto per un ordine WooCommerce (trovato o creato)."

msgid "New contact created in Holded for a WooCommerce customer."
msgstr "Nuovo contatto creato in Holded per un cliente WooCommerce."

msgid "Error while finding or creating the Holded contact for an order."
msgstr "Errore durante la ricerca o la creazione del contatto Holded per un ordine."

msgid "Holded invoice created after payment confirmation. Message contains the Holded invoice ID."
msgstr "Fattura creata in Holded dopo la conferma del pagamento. Il messaggio contiene l'ID fattura in Holded."

msgid "Error returned by Holded when creating an invoice for an order."
msgstr "Errore restituito da Holded durante la creazione di una fattura per un ordine."

msgid "Contact created but no ID returned by Holded."
msgstr "Contatto creato, ma Holded non ha restituito alcun ID."

#, php-format
msgid "WooCommerce order #%s"
msgstr "Ordine WooCommerce n. %s"

msgid "Shipping"
msgstr "Spedizione"
